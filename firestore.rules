rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // GIGS COLLECTION
    match /gigs/{gigId} {
      // Publicly readable
      allow read: if true;
      
      // Create requires auth and explicit ownerId mapping
      allow create: if request.auth != null 
                    && request.resource.data.ownerId == request.auth.uid;
      
      // Update/Delete requires ownership
      allow update: if request.auth != null 
                    && resource.data.ownerId == request.auth.uid
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['applicationCount', 'viewCount']));
                    
      allow delete: if request.auth != null 
                    && resource.data.ownerId == request.auth.uid;
    }

    // USERS COLLECTION
    match /users/{userId} {
      // Users can only read and write their own exact document map
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // APPLICATIONS COLLECTION
    match /applications/{applicationId} {
      // Anyone authenticated can create an application
      allow create: if request.auth != null 
                    && request.resource.data.applicantId == request.auth.uid;
                    
      // Only the applicant or the owner of the associated gig can read or update it
      allow read, update: if request.auth != null 
                          && (
                            resource.data.applicantId == request.auth.uid 
                            || get(/databases/$(database)/documents/gigs/$(resource.data.gigId)).data.ownerId == request.auth.uid
                          );
                          
      allow delete: if request.auth != null 
                    && resource.data.applicantId == request.auth.uid;
    }

  }
}
