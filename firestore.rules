rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // GIGS COLLECTION
    match /gigs/{gigId} {
      // Publicly readable
      allow read: if true;
      
      // Create requires auth and explicit ownerId mapping
      allow create: if request.auth != null 
                    && request.resource.data.ownerId == request.auth.uid;
      
      // Update/Delete requires ownership
      allow update: if request.auth != null 
                    && resource.data.ownerId == request.auth.uid
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['applicationCount', 'viewCount']));
                    
      allow delete: if request.auth != null 
                    && resource.data.ownerId == request.auth.uid;
    }

    // USERS COLLECTION
    match /users/{userId} {
      // Users can only read and write their own exact document map
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // APPLICATIONS COLLECTION
    match /applications/{applicationId} {
      // Anyone authenticated can create an application
      allow create: if request.auth != null 
                    && request.resource.data.applicantId == request.auth.uid;
                    
      // The applicant or the gig owner can read applications
      // Uses denormalized gigOwnerId field to avoid cross-collection get() which blocks list queries
      allow read: if request.auth != null 
                  && (
                    resource.data.applicantId == request.auth.uid 
                    || resource.data.gigOwnerId == request.auth.uid
                  );

      // Only the gig owner can update application status (accept/reject)
      allow update: if request.auth != null 
                    && resource.data.gigOwnerId == request.auth.uid;
                           
      allow delete: if request.auth != null 
                    && resource.data.applicantId == request.auth.uid;
    }

  }
}
